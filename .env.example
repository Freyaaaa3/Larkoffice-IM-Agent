# Feishu Bot credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# LLM configuration
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# 群聊两阶段门控用小模型时可单独指定（默认同 LLM_MODEL）
# LLM_MODEL_GATE=

# 群聊门控：1 开启（默认）| 0 关闭（行为同单聊直通）
# GROUP_GATE_ENABLED=1
# GROUP_GATE_BUFFER_MAX=28

# lark-cli 调用身份：bot（默认，无需用户 OAuth）| user（需已 lark-cli auth login --domain docs,slides,...）
# 若文档创建报 need_user_authorization，请改为 bot 或完成用户登录
LARK_CLI_IDENTITY=bot
