# Feishu Bot credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# LLM configuration
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# 群聊门控用小模型（可选，默认同 LLM_MODEL）
# LLM_MODEL_GATE=
# 门控小模型的 base_url（可选，默认同 LLM_BASE_URL；可指向本地 Ollama）
# LLM_BASE_URL_GATE=http://localhost:11434/v1
# 门控小模型的 API key（可选，默认同 LLM_API_KEY；Ollama 可填任意值如 ollama）
# LLM_API_KEY_GATE=ollama

# 群聊门控：1 开启（默认）| 0 关闭（行为同单聊直通）
# GROUP_GATE_ENABLED=1
# GROUP_GATE_BUFFER_MAX=28

# lark-cli 调用身份：bot（默认，无需用户 OAuth）| user（需已 lark-cli auth login --domain docs,slides,...）
# 若文档创建报 need_user_authorization，请改为 bot 或完成用户登录
LARK_CLI_IDENTITY=bot
